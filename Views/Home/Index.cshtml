@{
    ViewData["Title"] = "Main Page";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    /* home page overrides */
    main {
        max-width: 100% !important;
        margin: 0 !important;
        padding: 0 !important;
    }

    .home-hero {
        min-height: calc(100vh - 56px);
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 3rem 2rem;

        background-image: url('/img/hero-bg.png');
        background-size: cover;
        background-position: center;
    }

    /* dark overlay on photo */
    .home-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(10,15,30,.65) 0%,
            rgba(10,15,30,.55) 50%,
            rgba(10,15,30,.85) 100%
        );
    }

    .home-hero-content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1rem;
    }

    .home-hero h1 {
        font-size: clamp(2.4rem, 7vw, 4.5rem);
        font-weight: 800;
        letter-spacing: -.03em;
        line-height: 1.05;
        color: #fff;
    }

    .home-hero h2 {
        font-size: clamp(.95rem, 2.5vw, 1.25rem);
        font-weight: 400;
        color: rgba(255,255,255,.65);
        letter-spacing: .01em;
    }

    .home-hero-btn {
        margin-top: .75rem;
        display: inline-flex;
        align-items: center;
        gap: .5rem;
        padding: .85rem 2.25rem;
        background: var(--primary);
        color: #fff;
        font-size: 1rem;
        font-weight: 700;
        border-radius: 8px;
        text-decoration: none;
        transition: background .15s, transform .15s;
        box-shadow: 0 4px 20px rgba(79,142,247,.35);
    }
    .home-hero-btn:hover {
        background: var(--primary-h);
        color: #fff;
        transform: translateY(-2px);
    }
</style>

<section class="home-hero">
    <div class="home-hero-content">
        <h1>HeroAirlines Management</h1>
        <h2>Система управління авіапарком</h2>
        <a href="/airplanes" class="home-hero-btn">Авіапарк</a>
    </div>
</section>
